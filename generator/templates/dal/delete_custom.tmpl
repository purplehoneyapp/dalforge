{{define "delete_custom"}}
{{$entityTableName := .Name}}
{{$repoName := print (camelCase .Name) "Repository"}}
{{$softDelete := .Operations.SoftDelete}}
{{$columns := .Columns}}

{{range .Operations.Deletes}}
{{$delName := .Name}}
{{$delNamePascal := pascalCase .Name}}
{{$delNameCamel := camelCase .Name}}
{{$funcParams := deleteFuncParams . $columns}}
{{$funcCallParams := deleteFuncCallParams .}}
{{$queryParams := deleteQueryParams .}}

// {{$delNamePascal}} executes a custom bulk delete operation.
// 
// ⚠️ CAUTION - CACHE FLUSH NOTE ⚠️
// Because bulk deletions modify multiple records simultaneously, it is difficult to 
// track and selectively invalidate individual cache entries safely. Therefore, if 
// this operation successfully deletes one or more rows, it will trigger a global 
// FlushAllCache() to ensure local memory safety and broadcast cache invalidation 
// to peer nodes via Pub/Sub. Use this operation carefully in high-read environments.
//
// PERFORMANCE NOTE: To prevent database locks, undo-log bloat, and replication lag, 
// this operation requires a limit parameter. If the provided limit is <= 0 or > 5000, 
// it will be automatically clamped to 5000.
// 
// Example usage for bulk deletion:
//
//	batchSize := 5000
//	for {
//		rowsAffected, err := repo.{{$delNamePascal}}(ctx{{if $queryParams}}, /* args */{{end}}, batchSize)
//		if err != nil {
//			// handle error appropriately
//			break
//		}
//		if rowsAffected == 0 {
//			break // All matching rows have been processed
//		}
//		time.Sleep(100 * time.Millisecond) // Yield database resources between batches
//	}
func (d *{{$repoName}}) {{$delNamePascal}}(ctx context.Context{{if $funcParams}}, {{$funcParams}}{{end}}) (int64, error) {
    if d.configProvider.BlockedWrites("{{$entityTableName}}") {
        return 0, ErrOperationBlocked
    }

    // Clamp the limit to a safe range
    if limit <= 0 || limit > 5000 {
        limit = 5000
    }

    const operation = "{{$delName}}"
    d.telemetryProvider.IncDALOperation("{{$entityTableName}}", operation)

    result, err := d.dbBreaker.Execute(func() (interface{}, error) {
        return d.{{$delNameCamel}}(ctx{{if $funcCallParams}}, {{$funcCallParams}}{{end}})
    })

    if err != nil {
        return 0, err
    }

    rowsAffected := result.(int64)
    
    if rowsAffected > 0 {
        d.FlushAllCache() 
    }

    return rowsAffected, nil
}

func (d *{{$repoName}}) {{$delNameCamel}}(ctx context.Context{{if $funcParams}}, {{$funcParams}}{{end}}) (int64, error) {
    const operation = "{{$delName}}"
    dbStart := time.Now()

    // Inject the sanitized limit directly into the SQL string
    query := `{{deleteQuery $entityTableName . $columns $softDelete false}}` + fmt.Sprintf(" LIMIT %d", limit)

    db, dbErr := d.dbProvider.GetDatabase("{{$entityTableName | camelCase}}", true)
    if dbErr != nil {
        d.telemetryProvider.IncDBError("{{$entityTableName}}", operation)
        return 0, dbErr
    }

    {{if $queryParams}}
    res, err := db.ExecContext(ctx, query, {{$queryParams}})
    {{else}}
    res, err := db.ExecContext(ctx, query)
    {{end}}
    
    if err != nil {
        d.telemetryProvider.IncDBError("{{$entityTableName}}", operation)
        return 0, fmt.Errorf("failed to execute custom delete %s: %w", operation, err)
    }

    rowsAffected, err := res.RowsAffected()
    if err != nil {
        d.telemetryProvider.IncDBError("{{$entityTableName}}", operation)
        return 0, fmt.Errorf("failed to get rows affected: %w", err)
    }

    d.telemetryProvider.IncDBRequest("{{$entityTableName}}", operation)
    d.telemetryProvider.ObserveDBLatency("{{$entityTableName}}", operation, time.Since(dbStart).Seconds())
    
    return rowsAffected, nil
}

{{if $softDelete}}
// Hard{{$delNamePascal}} executes a permanent custom bulk delete operation.
// 
// PERFORMANCE NOTE: To prevent database locks, undo-log bloat, and replication lag, 
// this operation requires a limit parameter. If the provided limit is <= 0 or > 5000, 
// it will be automatically clamped to 5000.
// 
// Example usage for bulk deletion:
//
//	batchSize := 5000
//	for {
//		rowsAffected, err := repo.Hard{{$delNamePascal}}(ctx{{if $queryParams}}, /* args */{{end}}, batchSize)
//		if err != nil {
//			// handle error appropriately
//			break
//		}
//		if rowsAffected == 0 {
//			break // All matching rows have been processed
//		}
//		time.Sleep(100 * time.Millisecond) // Yield database resources between batches
//	}
func (d *{{$repoName}}) Hard{{$delNamePascal}}(ctx context.Context{{if $funcParams}}, {{$funcParams}}{{end}}) (int64, error) {
    if d.configProvider.BlockedWrites("{{$entityTableName}}") {
        return 0, ErrOperationBlocked
    }

    // Clamp the limit to a safe range
    if limit <= 0 || limit > 5000 {
        limit = 5000
    }

    const operation = "hard_{{$delName}}"
    d.telemetryProvider.IncDALOperation("{{$entityTableName}}", operation)

    result, err := d.dbBreaker.Execute(func() (interface{}, error) {
        return d.hard{{$delNamePascal}}(ctx{{if $funcCallParams}}, {{$funcCallParams}}{{end}})
    })

    if err != nil {
        return 0, err
    }

    rowsAffected := result.(int64)
    
    // Only flush caches if the database state actually changed
    if rowsAffected > 0 {
        d.FlushAllCache() 
    }

    return rowsAffected, nil
}

func (d *{{$repoName}}) hard{{$delNamePascal}}(ctx context.Context{{if $funcParams}}, {{$funcParams}}{{end}}) (int64, error) {
    const operation = "hard_{{$delName}}"
    dbStart := time.Now()

    // Inject the sanitized limit directly into the SQL string
    query := `{{deleteQuery $entityTableName . $columns $softDelete true}}` + fmt.Sprintf(" LIMIT %d", limit)

    db, dbErr := d.dbProvider.GetDatabase("{{$entityTableName | camelCase}}", true)
    if dbErr != nil {
        d.telemetryProvider.IncDBError("{{$entityTableName}}", operation)
        return 0, dbErr
    }

    {{if $queryParams}}
    res, err := db.ExecContext(ctx, query, {{$queryParams}})
    {{else}}
    res, err := db.ExecContext(ctx, query)
    {{end}}
    
    if err != nil {
        d.telemetryProvider.IncDBError("{{$entityTableName}}", operation)
        return 0, fmt.Errorf("failed to execute custom hard delete %s: %w", operation, err)
    }

    rowsAffected, err := res.RowsAffected()
    if err != nil {
        d.telemetryProvider.IncDBError("{{$entityTableName}}", operation)
        return 0, fmt.Errorf("failed to get rows affected: %w", err)
    }

    d.telemetryProvider.IncDBRequest("{{$entityTableName}}", operation)
    d.telemetryProvider.ObserveDBLatency("{{$entityTableName}}", operation, time.Since(dbStart).Seconds())
    
    return rowsAffected, nil
}
{{end}}

{{end}}
{{end}}